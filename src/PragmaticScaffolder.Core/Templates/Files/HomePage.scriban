@* <auto-generated /> *@
@page "/"

<PageTitle>{{ namespace }}</PageTitle>

<MudText Typo="Typo.h5" Class="mb-2">{{ namespace }}</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
    Select a feature from the navigation.
</MudText>

<MudList T="string" Dense="true">
{{- for f in features }}
    <MudListItem Href="/{{ f.route_prefix }}" Icon="@Icons.Material.Filled.TableView">{{ f.feature_folder }}</MudListItem>
{{- end }}
</MudList>
