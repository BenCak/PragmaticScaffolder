@page "/"
@using PragmaticScaffolder.Core.Services
@inject SqlServerSchemaReader SchemaReader
@inject ScaffolderState State
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Connect — Pragmatic Scaffolder</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1">Step 1 — Connect to Database</MudText>
<MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
    Enter your SQL Server connection string. The scaffolder reads the schema and never modifies your database.
</MudText>

@* Quick-connect profiles *@
<MudText Typo="Typo.caption" Class="mb-1 mud-text-secondary">Quick profiles</MudText>
<MudStack Row="true" Spacing="1" Class="mb-4">
    @foreach (var profile in ConnectionProfiles.All)
    {
        <MudChip T="string" Icon="@profile.Icon" Color="Color.Primary" Variant="Variant.Outlined"
                 OnClick="@(() => LoadProfile(profile))">
            @profile.Name
        </MudChip>
    }
</MudStack>

<MudPaper Class="pa-6" Elevation="2" Style="max-width:640px">
    <MudForm @ref="_form" @bind-IsValid="_valid">

        <MudTextField @bind-Value="_connStr" Label="Connection String"
                      Placeholder='Server=.;Database=Northwind;Trusted_Connection=true;TrustServerCertificate=true;'
                      FullWidth="true" Lines="3" Variant="Variant.Outlined"
                      Required="true" RequiredError="Connection string is required." Class="mb-4" />

        <MudTextField @bind-Value="State.RootNamespace" Label="Root Namespace"
                      Placeholder="MyApp" FullWidth="true" Variant="Variant.Outlined"
                      Required="true" RequiredError="Namespace is required." Class="mb-4"
                      HelperText='Used as the C# namespace and folder name (e.g. "NorthwindApp").' />

        <MudTextField @bind-Value="State.OutputPath" Label="Output Folder"
                      Placeholder="/home/ben/code/MyGeneratedApp" FullWidth="true" Variant="Variant.Outlined"
                      Required="true" RequiredError="Output folder is required." Class="mb-4"
                      HelperText="The generated solution will be written here." />

        <MudTextField @bind-Value="State.TablePrefix" Label="Table Prefix to Strip"
                      Placeholder="tbl" FullWidth="true" Variant="Variant.Outlined" Class="mb-4"
                      HelperText='Optional. Strips this prefix from table names in generated code (e.g. "tbl" turns "tblCustomer" → "Customer").' />

        <MudTextField @bind-Value="State.SpPrefix" Label="Stored Procedure Prefix to Strip"
                      Placeholder="usp_" FullWidth="true" Variant="Variant.Outlined" Class="mb-4"
                      HelperText='Optional. Strips this prefix from SP names (e.g. "usp_" turns "usp_tblOrders_Search" → "tblOrders_Search", then table prefix strips further).' />

        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       Disabled="_busy || !_valid" OnClick="ConnectAsync">
                @(_busy ? "Connecting…" : "Connect & Load Schema")
            </MudButton>
            @if (_busy)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
        </MudStack>
    </MudForm>
</MudPaper>

@code {
    private MudForm _form = default!;
    private bool _valid;
    private bool _busy;
    private string _connStr = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _form.Validate(); // enable the Connect button on pre-filled profiles
            StateHasChanged();
        }
    }

    protected override void OnInitialized()
    {
        // Pre-fill from state if already connected, otherwise use the default test profile
        if (!string.IsNullOrEmpty(State.ConnectionString))
        {
            _connStr = State.ConnectionString;
        }
        else
        {
            LoadProfile(ConnectionProfiles.All[0]);
        }
    }

    private void LoadProfile(ConnectionProfile profile)
    {
        _connStr              = profile.ConnectionString;
        State.RootNamespace   = profile.DefaultNamespace;
        State.OutputPath      = profile.DefaultOutputPath;
        State.TablePrefix     = profile.TablePrefix;
        State.SpPrefix        = profile.SpPrefix;
    }

    private async Task ConnectAsync()
    {
        await _form.Validate();
        if (!_valid) return;

        _busy = true;
        State.ConnectionString = _connStr;

        try
        {
            var ok = await SchemaReader.TestConnectionAsync(_connStr);
            if (!ok)
            {
                Snackbar.Add("Could not connect. Check the connection string and try again.", Severity.Error);
                return;
            }

            Snackbar.Add("Connected! Loading schema…", Severity.Info);
            State.Database = await SchemaReader.ReadDatabaseAsync(_connStr);
            State.SelectedTableKeys.Clear();
            State.SelectedProcKeys.Clear();
            Nav.NavigateTo("/tables");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
